# ============================================================
# SAMA - Local Environment Configuration
# ============================================================
# 复制此文件为 .env.local 并填写你的值
# ⚠️ 不要将 .env.local 提交到版本控制！

# ─────────────────────────────────────────────────────────────
# Supabase 配置
# ─────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://hblorxugmnntgbcvrjez.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_SUPABASE_SERVICE_KEY=your_service_key_here

# ─────────────────────────────────────────────────────────────
# REPORT_SECRET (团队共享密码)
# ─────────────────────────────────────────────────────────────
# ⚠️ 这个密码需要与 Supabase Edge Function 中配置的一致
# ⚠️ 请在 Supabase Dashboard > Project Settings > Edge Functions > Secrets 中配置
VITE_REPORT_SECRET=sama-team-2026

# ─────────────────────────────────────────────────────────────
# Ayrshare API 配置 (仅用于本地开发时的直接调用)
# ⚠️ 生产环境应通过 Supabase Edge Function 安全地调用
# ─────────────────────────────────────────────────────────────
AYRSHARE_API_KEY=your_ayrshare_api_key_here

# ─────────────────────────────────────────────────────────────
# X/Twitter BYO API Credentials
# (自 2026 年 3 月 31 日起需要)
# https://www.ayrshare.com/docs/dashboard/connect-social-accounts/x-twitter-byo-keys
# ─────────────────────────────────────────────────────────────
X_API_KEY=your_x_api_key_here
X_API_SECRET=your_x_api_secret_here
